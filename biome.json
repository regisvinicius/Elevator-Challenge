{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "include": ["src/web/**/*.ts", "src/web/**/*.tsx"],
    "ignore": [
      "src/web/node_modules",
      "src/web/dist",
      "**/tsconfig*.json",
      "**/*.config.ts"
    ]
  }
}
